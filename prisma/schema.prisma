datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String      @id @default(cuid())
  email              String?     @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  spotifyId          String?     @unique
  username           String?     @unique
  bio                String?
  isVerifiedReviewer Boolean     @default(false)
  credibilityScore   Int         @default(0)

  accounts           Account[]
  sessions           Session[]

  topArtists         UserArtist[]
  topTracks          UserTrack[]
  genres             UserGenre[]

  following          Follow[]    @relation("UserFollowing")
  followers          Follow[]    @relation("UserFollowers")

  reviews            Review[]
  ratings            Rating[]
  lists              List[]

  spotifyDataSyncedAt DateTime?

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([spotifyId])
  @@index([username])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Artist {
  id         String       @id @default(cuid())
  spotifyId  String       @unique
  name       String
  imageUrl   String?
  genres     String[]
  popularity Int?

  users      UserArtist[]

  @@index([spotifyId])
  @@index([name])
}

model Track {
  id             String      @id @default(cuid())
  spotifyId      String      @unique
  name           String
  artistName     String
  artistSpotifyId String?
  albumName      String?
  albumImageUrl  String?
  durationMs     Int?
  previewUrl     String?

  users          UserTrack[]
  reviews        Review[]
  ratings        Rating[]

  @@index([spotifyId])
  @@index([artistName])
}

model UserArtist {
  id        String    @id @default(cuid())
  userId    String
  artistId  String
  timeRange TimeRange
  rank      Int

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist    Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)

  updatedAt DateTime  @updatedAt

  @@unique([userId, artistId, timeRange])
  @@index([userId, timeRange])
  @@index([artistId])
}

model UserTrack {
  id        String    @id @default(cuid())
  userId    String
  trackId   String
  timeRange TimeRange
  rank      Int

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  track     Track     @relation(fields: [trackId], references: [id], onDelete: Cascade)

  updatedAt DateTime  @updatedAt

  @@unique([userId, trackId, timeRange])
  @@index([userId, timeRange])
  @@index([trackId])
}

model UserGenre {
  id     String @id @default(cuid())
  userId String
  genre  String
  score  Float

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, genre])
  @@index([userId])
}

enum TimeRange {
  SHORT_TERM
  MEDIUM_TERM
  LONG_TERM
}

model Review {
  id               String   @id @default(cuid())
  userId           String
  trackId          String?
  albumSpotifyId   String?
  artistSpotifyId  String?
  body             String   @db.Text
  rating           Float?
  isVerifiedReview Boolean  @default(false)

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track            Track?   @relation(fields: [trackId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([trackId])
  @@index([albumSpotifyId])
  @@index([artistSpotifyId])
  @@index([createdAt])
}

model Rating {
  id              String   @id @default(cuid())
  userId          String
  trackId         String?
  albumSpotifyId  String?
  artistSpotifyId String?
  score           Float
  isVerified      Boolean  @default(false)

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track           Track?   @relation(fields: [trackId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, trackId])
  @@unique([userId, albumSpotifyId])
  @@unique([userId, artistSpotifyId])
  @@index([userId])
  @@index([trackId])
  @@index([albumSpotifyId])
}

model List {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?    @db.Text
  isPublic    Boolean    @default(true)

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       ListItem[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([isPublic, createdAt])
}

model ListItem {
  id              String @id @default(cuid())
  listId          String
  trackId         String?
  albumSpotifyId  String?
  artistSpotifyId String?
  rank            Int
  note            String?

  list            List   @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String

  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}
